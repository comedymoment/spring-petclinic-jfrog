name: Test Maven Auth

on:
  workflow_dispatch:

jobs:
  test:
    runs-on: ubuntu-latest

    env:
      JF_URL: ${{ secrets.JF_URL }}
      JF_ACCESS_TOKEN: ${{ secrets.JF_ACCESS_TOKEN }}

    steps:
      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - uses: jfrog/setup-jfrog-cli@v4

      - name: Configure JFrog CLI
        run: |
          jf c add my-server \
            --url "$JF_URL" \
            --access-token "$JF_ACCESS_TOKEN" \
            --interactive=false \
            --overwrite=true

      - name: Configure Maven
        run: |
          jf mvn-config \
            --server-id-resolve my-server \
            --repo-resolve-releases maven-virtual \
            --repo-resolve-snapshots maven-virtual

      - name: Test Maven Resolve
        run: |
          mvn dependency:get \
            -DrepoUrl=${JF_URL}/artifactory/maven-virtual \
            -Dartifact=org.springframework.boot:spring-boot-starter-parent:4.0.3:pom
